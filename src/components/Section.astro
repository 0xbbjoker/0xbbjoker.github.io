---
interface Props {
  id?: string;
  kicker: string;
  title: string;
  border?: boolean;
}

const { id, kicker, title, border = true } = Astro.props;
---

<section
  id={id}
  class:list={[
    "py-10 sm:py-12",
    border ? "border-t" : "pt-0",
  ]}
>
  <p
    class="mb-2 font-mono text-xs font-semibold uppercase tracking-[0.1em] text-muted-foreground"
  >
    {kicker}
  </p>
  <h2 class="text-2xl font-semibold tracking-tight sm:text-[1.75rem]">
    {title}
  </h2>
  <div class="mt-6">
    <slot />
  </div>
</section>
