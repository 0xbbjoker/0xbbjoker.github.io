---
import { contact } from "../data/cv";
import Button from "./Button.astro";
import ThemeToggle from "./ThemeToggle.astro";

const links = [
  { href: "#profile", label: "Profile" },
  { href: "#experience", label: "Experience" },
  { href: "#work", label: "Work" },
  { href: "#contact", label: "Contact" },
];
---

<header class="sticky top-0 z-50 border-b bg-background/80 backdrop-blur-md">
  <nav
    class="mx-auto flex h-16 w-full max-w-5xl items-center gap-4 px-4 sm:px-6"
    aria-label="Main"
  >
    <a
      href="#top"
      class="flex items-center gap-2.5 font-semibold tracking-tight"
      aria-label="Benjamin Berta — home"
    >
      <span
        class="grid size-7 place-items-center rounded-md bg-primary font-mono text-xs font-bold text-primary-foreground"
        >0x</span
      >
      <span class="hidden sm:inline">Benjamin Berta</span>
    </a>

    <div class="ml-auto hidden items-center gap-1 md:flex">
      {
        links.map((l) => (
          <a
            href={l.href}
            class="rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground"
          >
            {l.label}
          </a>
        ))
      }
    </div>

    <div class="ml-auto flex items-center gap-2 md:ml-3">
      <ThemeToggle />
      <Button href={contact.pdf} variant="outline" size="sm" download>
        Download PDF
      </Button>
    </div>
  </nav>
</header>
