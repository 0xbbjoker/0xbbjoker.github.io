---
import { experience } from "../data/cv";
---

<div class="space-y-4">
  {
    experience.map((role) => (
      <article class="rounded-lg border bg-card p-5 sm:p-6">
        <div class="flex flex-wrap items-baseline justify-between gap-x-4 gap-y-1">
          <div>
            <h3 class="text-base font-semibold sm:text-lg">{role.title}</h3>
            <p class="text-sm font-medium text-muted-foreground">{role.org}</p>
          </div>
          <span class="whitespace-nowrap font-mono text-xs text-muted-foreground">
            {role.period}
          </span>
        </div>

        {role.links && (
          <div class="mt-3 flex flex-wrap gap-2">
            {role.links.map((l) => (
              <a
                href={l.href}
                class="inline-flex items-center gap-1 rounded-md border px-2 py-1 text-xs font-medium text-muted-foreground transition-colors hover:bg-muted hover:text-foreground"
              >
                {l.label} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )}

        <ul class="mt-4 space-y-2">
          {role.bullets.map((b) => (
            <li class="relative pl-4 text-sm leading-relaxed text-foreground/80 before:absolute before:left-0 before:top-[0.62em] before:size-1 before:rounded-full before:bg-muted-foreground/60 before:content-['']">
              {b}
            </li>
          ))}
        </ul>

        {role.stack && (
          <p class="mt-4 border-t pt-3 text-xs leading-relaxed text-muted-foreground">
            {role.stack}
          </p>
        )}
      </article>
    ))
  }
</div>
