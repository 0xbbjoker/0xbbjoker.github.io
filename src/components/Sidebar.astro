---
import { engagement, skills, credentials, education, contact } from "../data/cv";
import Button from "./Button.astro";

const contactLinks = [
  { href: `mailto:${contact.email}`, label: contact.email, wrap: true },
  { href: contact.github, label: contact.githubLabel },
  { href: contact.linkedin, label: contact.linkedinLabel },
  { href: contact.x, label: contact.xLabel },
  { href: contact.auto, label: contact.autoLabel },
];
---

<div class="space-y-4">
  <section class="rounded-lg border bg-card p-5">
    <h2 class="text-sm font-semibold">Engagement</h2>
    <p class="mt-2 text-sm leading-relaxed text-muted-foreground">{engagement}</p>
  </section>

  <section class="rounded-lg border bg-card p-5">
    <h2 class="text-sm font-semibold">Technical skills</h2>
    <div class="mt-3 space-y-3">
      {
        skills.map((g) => (
          <div class="border-t pt-3 first:border-t-0 first:pt-0">
            <p class="font-mono text-[0.7rem] font-semibold uppercase tracking-wider text-muted-foreground">
              {g.label}
            </p>
            <p class="mt-1 text-sm leading-relaxed text-foreground/80">
              {g.items}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="rounded-lg border bg-card p-5">
    <h2 class="text-sm font-semibold">Education & credentials</h2>
    <ul class="mt-3 space-y-2 text-sm leading-relaxed text-muted-foreground">
      {[...credentials, ...education].map((c) => <li>{c}</li>)}
    </ul>
  </section>

  <section id="contact" class="rounded-lg border bg-card p-5">
    <h2 class="text-sm font-semibold">Contact</h2>
    <div class="mt-3 grid gap-1.5 text-sm">
      {
        contactLinks.map((l) => (
          <a
            href={l.href}
            class:list={[
              "text-muted-foreground transition-colors hover:text-foreground",
              l.wrap && "break-words",
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </div>
    <Button
      id="copy-email"
      variant="outline"
      size="sm"
      class="mt-4 w-full"
      data-copy={contact.email}
    >
      Copy email
    </Button>
  </section>
</div>

<script is:inline>
  document.getElementById("copy-email")?.addEventListener("click", async (e) => {
    const btn = e.currentTarget;
    const value = btn.getAttribute("data-copy");
    if (!value) return;
    try {
      await navigator.clipboard.writeText(value);
      const label = btn.textContent;
      btn.textContent = "Copied";
      setTimeout(() => {
        btn.textContent = label;
      }, 1400);
    } catch {
      window.location.href = "mailto:" + value;
    }
  });
</script>
