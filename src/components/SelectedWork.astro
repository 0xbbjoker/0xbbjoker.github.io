---
import { selectedWork, earlierWork } from "../data/cv";
import Badge from "./Badge.astro";
---

<div class="grid gap-4 sm:grid-cols-2">
  {
    selectedWork.map((w) => (
      <article
        class:list={[
          "flex flex-col rounded-lg border bg-card p-5 sm:p-6",
          w.featured && "sm:col-span-2",
        ]}
      >
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold">{w.name}</h3>
          {w.tag && <Badge variant="outline">{w.tag}</Badge>}
        </div>
        <p class="mt-3 text-sm leading-relaxed text-muted-foreground">
          {w.body}
        </p>
        {w.href && (
          <a
            href={w.href}
            class="mt-4 inline-flex w-fit items-center gap-1 text-sm font-medium underline-offset-4 hover:underline"
          >
            {w.hrefLabel} <span aria-hidden="true">↗</span>
          </a>
        )}
      </article>
    ))
  }
</div>

<p class="mt-4 text-sm leading-relaxed text-muted-foreground">{earlierWork}</p>
