---
import { selectedWork } from "../data/cv";
import Badge from "./Badge.astro";
---

<div class="grid gap-4 sm:grid-cols-2">
  {
    selectedWork.map((w) => (
      <article
        class:list={[
          "flex flex-col rounded-lg border bg-card p-5 sm:p-6",
          w.featured && "sm:col-span-2",
        ]}
      >
        <div class="flex items-center justify-between gap-3">
          <h3 class="text-base font-semibold">{w.name}</h3>
          {w.tag && <Badge variant="outline">{w.tag}</Badge>}
        </div>
        <p class="mt-3 grow text-sm leading-relaxed text-muted-foreground">
          {w.body}
        </p>
        {w.links && (
          <div class="mt-4 flex flex-wrap gap-x-4 gap-y-1">
            {w.links.map((l) => (
              <a
                href={l.href}
                class="inline-flex items-center gap-1 text-sm font-medium underline-offset-4 hover:underline"
              >
                {l.label} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        )}
      </article>
    ))
  }
</div>
